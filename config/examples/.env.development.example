# ============================================
# РАЗРАБОТКА (DEVELOPMENT)
# ============================================
#
# Инструкция:
# 1. Скопируйте в корень: cp config/examples/.env.development.example .env.development
# 2. Заполните необходимые значения
# 3. Загрузите в приложении: require('dotenv').config({ path: '.env.development' })
#
# ============================================

NODE_ENV=development

# Отладка
DEBUG=true
DEBUG_SQL=true
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Приложение
APP_URL=http://localhost:3000
PORT=3000

# База данных (локальная)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_template_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (локальный)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Безопасность (упрощенная для dev)
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRES_IN=30d
SESSION_SECRET=dev-session-secret

# CORS (разрешить все localhost порты)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:8080

# Отключить ограничения
DISABLE_RATE_LIMIT=true

# Email (использовать Mailhog или Mailtrap для тестирования)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@localhost

# Файлы
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50mb

# Background jobs
ENABLE_BACKGROUND_JOBS=true

# Hot reload / Watch режим
WATCH_FILES=true
