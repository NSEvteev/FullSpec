# ============================================
# ТЕСТИРОВАНИЕ (TEST)
# ============================================
#
# Используется для запуска автоматических тестов
# (unit, integration, e2e)
#
# Инструкция:
# 1. Скопируйте в корень: cp config/examples/.env.test.example .env.test
# 2. Заполните необходимые значения
# 3. Используйте в тестах: require('dotenv').config({ path: '.env.test' })
#
# ============================================

NODE_ENV=test

# Отладка тестов
DEBUG=false
DEBUG_SQL=false
LOG_LEVEL=error
LOG_FORMAT=json

# Приложение
APP_URL=http://localhost:3001
PORT=3001

# База данных (тестовая, будет очищаться)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_template_test
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (тестовый)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# Безопасность (упрощенная для тестов)
JWT_SECRET=test-secret-key
JWT_EXPIRES_IN=1h
SESSION_SECRET=test-session-secret

# CORS (разрешить все для тестов)
CORS_ORIGINS=*

# Отключить ограничения для быстрых тестов
DISABLE_RATE_LIMIT=true

# Email (использовать mock)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=test@localhost

# Файлы (использовать временную директорию)
STORAGE_TYPE=local
UPLOAD_DIR=./tmp/test-uploads
MAX_FILE_SIZE=5mb

# Background jobs (отключить для быстрых тестов)
ENABLE_BACKGROUND_JOBS=false

# Отключить внешние API (использовать моки)
DISABLE_EXTERNAL_APIS=true

# Ускорить выполнение
BCRYPT_ROUNDS=4
DISABLE_EMAIL_SENDING=true

# Timezone
TZ=UTC
