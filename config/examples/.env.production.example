# ============================================
# ПРОДАКШЕН (PRODUCTION)
# ============================================
#
# ВНИМАНИЕ: Используйте надежные пароли и секреты!
# Рекомендуется использовать систему управления секретами
# (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# Инструкция:
# 1. Скопируйте в корень: cp config/examples/.env.production.example .env.production
# 2. Заполните РЕАЛЬНЫЕ значения
# 3. Убедитесь что .env.production в .gitignore
# 4. Используйте переменные окружения сервера вместо файла
#
# ============================================

NODE_ENV=production

# Отладка - ОТКЛЮЧЕНО
DEBUG=false
DEBUG_SQL=false
LOG_LEVEL=warn
LOG_FORMAT=json

# Приложение
APP_URL=https://your-domain.com
PORT=8080

# База данных (Production)
DB_HOST=production-db-host.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=project_template_prod
DB_USER=prod_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_SIZE=20

# Или используйте строку подключения из Secrets Manager
# DATABASE_URL=postgresql://user:pass@host:5432/db?ssl=true

# Redis (Production)
REDIS_HOST=production-redis.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# Безопасность - КРИТИЧНО!
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_256BIT_SECRET
JWT_EXPIRES_IN=7d
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_256BIT_SECRET

# CORS (только доверенные домены)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com,https://app.your-domain.com

# Rate limiting - ВКЛЮЧЕНО
DISABLE_RATE_LIMIT=false

# Email (Production SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
SMTP_FROM=noreply@your-domain.com

# Файлы (использовать S3 или облачное хранилище)
STORAGE_TYPE=s3
UPLOAD_DIR=s3://your-bucket/uploads
MAX_FILE_SIZE=10mb

# AWS (если используется S3)
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket

# Background jobs
ENABLE_BACKGROUND_JOBS=true

# Мониторинг
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# SSL/TLS
# FORCE_HTTPS=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Timezone
TZ=UTC
