# ============================================================
# Environment variables for tests
# Только публичные значения — файл коммитится в git
# ============================================================

# --- PostgreSQL (test) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=myapp
POSTGRES_PASSWORD=test

# Per-service databases
AUTH_DB_NAME=myapp_auth
TASK_DB_NAME=myapp_task
NOTIFICATION_DB_NAME=myapp_notification
ADMIN_DB_NAME=myapp_admin

# --- Redis (test) ---
REDIS_HOST=localhost
REDIS_PORT=6380
NOTIFICATION_REDIS_DB=0
AUTH_REDIS_DB=1

# --- RabbitMQ (test) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5673

# --- Service URLs (localhost for tests) ---
AUTH_SERVICE_URL=http://localhost:8001
TASK_SERVICE_URL=http://localhost:8002
NOTIFICATION_SERVICE_URL=http://localhost:8003
ADMIN_SERVICE_URL=http://localhost:8004

# --- JWT (test) ---
JWT_SECRET_KEY=test-secret-key-not-for-production
