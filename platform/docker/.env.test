# ============================================================
# Environment variables for tests
# Только публичные значения — файл коммитится в git
# ============================================================

# --- PostgreSQL (test) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=myapp
POSTGRES_PASSWORD=test

# Per-service databases (добавить при создании сервиса через analysis chain)
# {SVC}_DB_NAME=myapp_{svc}

# --- Redis (test) ---
REDIS_HOST=localhost
REDIS_PORT=6380
# {SVC}_REDIS_DB=0

# --- RabbitMQ (test) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5673

# --- Service URLs (добавить при создании сервиса через analysis chain) ---
# {SVC}_SERVICE_URL=http://localhost:{port}
