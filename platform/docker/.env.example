# ============================================================
# Environment variables for MyApp
# SSOT: specs/docs/.system/infrastructure.md
# ============================================================
# Скопировать в .env и изменить секреты:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=myapp
POSTGRES_PASSWORD=changeme

# Per-service databases (добавить при создании сервиса через analysis chain)
# {SVC}_DB_NAME=myapp_{svc}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# {SVC}_REDIS_DB=0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# --- Service URLs (добавить при создании сервиса через analysis chain) ---
# {SVC}_SERVICE_URL=http://{svc}:{port}
