# ============================================================
# Environment variables for MyApp
# SSOT: specs/docs/.system/infrastructure.md
# ============================================================
# Скопировать в .env и изменить секреты:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=myapp
POSTGRES_PASSWORD=changeme

# Per-service databases
AUTH_DB_NAME=myapp_auth
TASK_DB_NAME=myapp_task
NOTIFICATION_DB_NAME=myapp_notification
ADMIN_DB_NAME=myapp_admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
NOTIFICATION_REDIS_DB=0
AUTH_REDIS_DB=1

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# --- Service URLs (Docker network) ---
AUTH_SERVICE_URL=http://auth:8001
TASK_SERVICE_URL=http://task:8002
NOTIFICATION_SERVICE_URL=http://notification:8003
ADMIN_SERVICE_URL=http://admin:8004

# --- JWT ---
JWT_SECRET_KEY=changeme-use-a-real-secret-in-production
