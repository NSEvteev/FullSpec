# ============================================
# БАЗОВЫЙ ШАБЛОН ПЕРЕМЕННЫХ ОКРУЖЕНИЯ
# ============================================
#
# Инструкция:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Заполните необходимые значения
# 3. НЕ КОММИТЬТЕ .env в Git (он в .gitignore)
#
# Для специфичных окружений смотрите config/examples/
# ============================================

# --------------------------------------------
# Общие настройки приложения
# --------------------------------------------

# Окружение: development, production, staging, test
NODE_ENV=development

# Название приложения
APP_NAME="Project Template"

# Версия приложения
APP_VERSION=1.0.0

# URL приложения
APP_URL=http://localhost:3000

# Порт приложения
PORT=3000

# --------------------------------------------
# База данных
# --------------------------------------------

# Тип БД: postgresql, mysql, sqlite, mongodb
DB_TYPE=postgresql

# Хост БД
DB_HOST=localhost

# Порт БД
DB_PORT=5432

# Имя базы данных
DB_NAME=project_template

# Пользователь БД
DB_USER=postgres

# Пароль БД
DB_PASSWORD=

# Connection pool размер
DB_POOL_SIZE=10

# Строка подключения (альтернатива отдельным параметрам)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --------------------------------------------
# Redis / Кэширование
# --------------------------------------------

# Redis хост
REDIS_HOST=localhost

# Redis порт
REDIS_PORT=6379

# Redis пароль
REDIS_PASSWORD=

# Redis база данных (0-15)
REDIS_DB=0

# --------------------------------------------
# Аутентификация и безопасность
# --------------------------------------------

# Секретный ключ для JWT (генерируйте случайный!)
JWT_SECRET=

# Время жизни токена (в секундах или формате: 1h, 7d, 30d)
JWT_EXPIRES_IN=7d

# Секрет для сессий
SESSION_SECRET=

# Разрешенные CORS origins (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --------------------------------------------
# Email / SMTP
# --------------------------------------------

# SMTP хост
SMTP_HOST=smtp.gmail.com

# SMTP порт
SMTP_PORT=587

# SMTP пользователь
SMTP_USER=

# SMTP пароль
SMTP_PASSWORD=

# Email отправителя
SMTP_FROM=noreply@example.com

# --------------------------------------------
# Внешние API
# --------------------------------------------

# API ключи (примеры)
# OPENAI_API_KEY=
# STRIPE_API_KEY=
# GOOGLE_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --------------------------------------------
# Логирование
# --------------------------------------------

# Уровень логов: error, warn, info, debug, trace
LOG_LEVEL=info

# Формат логов: json, pretty
LOG_FORMAT=pretty

# Путь к файлу логов
LOG_FILE_PATH=./logs/app.log

# --------------------------------------------
# Мониторинг и метрики
# --------------------------------------------

# Sentry DSN для отслеживания ошибок
# SENTRY_DSN=

# --------------------------------------------
# Разработка / Отладка
# --------------------------------------------

# Включить debug режим
DEBUG=false

# Показывать SQL запросы
DEBUG_SQL=false

# Отключить rate limiting в dev режиме
DISABLE_RATE_LIMIT=false

# --------------------------------------------
# Файловое хранилище
# --------------------------------------------

# Тип хранилища: local, s3, gcs
STORAGE_TYPE=local

# Локальный путь для загрузок
UPLOAD_DIR=./uploads

# Максимальный размер файла (в байтах или формате: 5mb, 100kb)
MAX_FILE_SIZE=10mb

# --------------------------------------------
# Webhook / Background Jobs
# --------------------------------------------

# Webhook URL для уведомлений
# WEBHOOK_URL=

# Включить background jobs
ENABLE_BACKGROUND_JOBS=true

# --------------------------------------------
# Прочее
# --------------------------------------------

# Timezone
TZ=UTC

# Язык по умолчанию
DEFAULT_LANGUAGE=ru
