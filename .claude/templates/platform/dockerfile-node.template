# Multi-stage Node.js Dockerfile Template

# Источник: /.claude/instructions/platform/docker.md

# syntax=docker/dockerfile:1

# ============================================
# Stage 1: Base - общие зависимости
# ============================================
FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache dumb-init

# ============================================
# Stage 2: Dependencies - production зависимости
# ============================================
FROM base AS deps
COPY package*.json ./
RUN npm ci --only=production

# ============================================
# Stage 3: Builder - сборка приложения
# ============================================
FROM base AS builder
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ============================================
# Stage 4: Production - финальный образ
# ============================================
FROM base AS production

# Метаданные
LABEL org.opencontainers.image.source="https://github.com/org/repo"
LABEL org.opencontainers.image.description="Service description"
LABEL org.opencontainers.image.version="1.0.0"

# Переменные окружения
ENV NODE_ENV=production

# Копирование артефактов
COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist

# Безопасность: не root пользователь
USER node

# Порт
EXPOSE 3000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/health || exit 1

# Запуск с init системой
CMD ["dumb-init", "node", "dist/server.js"]


# ============================================
# .dockerignore (создать рядом с Dockerfile)
# ============================================
# .git
# .gitignore
# *.md
# !README.md
# node_modules
# __pycache__
# .env*
# .vscode
# .idea
# coverage
# dist
# ============================================


# Сборка:
# docker build -t myapp:v1.0.0 --target production .
#
# Запуск:
# docker run -p 3000:3000 -e API_KEY=$API_KEY myapp:v1.0.0
#
# Для разработки (с volume mount):
# docker run -p 3000:3000 -v $(pwd):/app myapp:v1.0.0 npm run dev
